## Backend environment variables
## Copy this file to `.env` for local development.
##
## DEV (SQLite)
## NOTE: for SQLite, relative paths are resolved from the `prisma/` folder (schema location).
## This stores the DB at `concesionaria-backend/prisma/dev.db`.
DATABASE_URL="file:./dev.db"
DIRECT_URL=""
##
## AUTH
## Use a long random string (>= 32 chars)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"
##
## Email (optional in dev)
RESEND_API_KEY=""
##
## Media (optional in dev)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
##
## App
FRONTEND_URL="http://localhost:3000"
PORT="4000"
NODE_ENV="development"
##
## STAGING/PRODUCTION example (Postgres)
## DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
## DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DATABASE_URL=
DIRECT_URL=
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000
PORT=4000
